# ─── Active AI Provider (chat UI) ───
# Valid values: openai | nim | perplexity | lmstudio | ollama
AI_PROVIDER=nim

# ─── Pipeline Job AI Provider ───
# Controls which backend batch jobs (analyze-surveys, risk-forecast, etc.) use.
# Valid values: ollama | groq | cerebras | nim
# Default: ollama (points at OLLAMA_BASE_URL — can be local or Colab via ngrok)
JOB_AI_PROVIDER=ollama

# Ollama Configuration (local or remote via Colab ngrok tunnel)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=gemma3:4b
OLLAMA_JOB_MODEL=qwen3:4b

# Groq (https://console.groq.com — free: 500K tokens/day)
GROQ_API_KEY=

# Cerebras (https://cloud.cerebras.ai — free: 1M tokens/day)
CEREBRAS_API_KEY=

# OpenAI API Key for LLM features
OPENAI_API_KEY=your_api_key_here

GOOGLE_GENERATIVE_AI_API_KEY=""

# NVIDIA NIM (https://build.nvidia.com — 1000 free inference credits)
NIM_API_KEY=""

# Perplexity (https://docs.perplexity.ai)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# LM Studio (local, no API key needed)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=loaded-model

# SQL Server (Connect Module) — Docker
SQLSERVER_SERVER=localhost
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=SqlServer@123!
SQLSERVER_DATABASE=WOVO

# PostgreSQL (Engage + AI) — Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DATABASE=wovo_new
POSTGRES_DATABASE_WOVO_AI=wovo_ai

# MySQL (Educate/Moodle) — Docker
MYSQL_HOST=127.0.0.1
MYSQL_USER=moodle
MYSQL_PASSWORD=moodlepass
MYSQL_DATABASE=iomadprod
