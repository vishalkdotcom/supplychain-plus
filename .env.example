# ─── Demo Mode (Vercel intelligence-first deploy) ───
# When true, the app uses demo as-of clock, read-only mutations, jobs off, and route/tool allowlists.
# DEMO_MODE=true
# DEMO_AS_OF=2025-06-15T12:00:00.000Z
# Mirror these on Vercel for client-side relative ages (freshness badges, connect pages):
# NEXT_PUBLIC_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_AS_OF=2025-06-15T12:00:00.000Z
# DEMO_USERNAME=demo
# DEMO_PASSWORD=change-me
# DEMO_SESSION_SECRET=change-me-in-production

# ─── Active AI Provider (chat UI) ───
# Valid values: openai | nim | perplexity | lmstudio | ollama
AI_PROVIDER=nim

# ─── Pipeline Job AI Model Cascade ───
# Cross-provider cascade: tries models in order, falls through on 429/5xx.
# Format: provider:model,provider:model,...
# Default (if unset): 11-model quality-first cascade across Groq + Cerebras (~5.8M TPD)
# JOB_AI_CASCADE=cerebras:qwen-3-235b-a22b-instruct-2507,cerebras:gpt-oss-120b,groq:openai/gpt-oss-120b,groq:llama-3.3-70b-versatile,groq:meta-llama/llama-4-scout-17b-16e-instruct,groq:qwen/qwen3-32b,groq:moonshotai/kimi-k2-instruct,groq:openai/gpt-oss-20b,cerebras:llama3.1-8b,groq:llama-3.1-8b-instant,groq:allam-2-7b

# Legacy (backward compat — used only if JOB_AI_CASCADE is not set):
# JOB_AI_PROVIDER=groq
# JOB_AI_FALLBACK=cerebras

# Rate limit overrides (optional — defaults match free tier).
# Provider-wide: RATELIMIT_<PROVIDER>_TPM / _RPM / _TPD / _RPD
# Model-specific: RATELIMIT_<PROVIDER>_<MODEL>_TPM (dots/dashes/slashes → underscores)
# RATELIMIT_GROQ_TPM=12000
# RATELIMIT_GROQ_RPM=30
# RATELIMIT_CEREBRAS_TPD=1000000
# RATELIMIT_GROQ_LLAMA_3_3_70B_VERSATILE_TPD=100000

# Ollama Configuration (local only — used for bge-m3 embeddings in case-clustering)
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=gemma3:4b

# Groq (https://console.groq.com — free: 500K tokens/day)
GROQ_API_KEY=

# Cerebras (https://cloud.cerebras.ai — free: 1M tokens/day)
CEREBRAS_API_KEY=

# OpenAI API Key for LLM features
OPENAI_API_KEY=your_api_key_here

GOOGLE_GENERATIVE_AI_API_KEY=""

# NVIDIA NIM (https://build.nvidia.com — 1000 free inference credits)
NIM_API_KEY=""

# Perplexity (https://docs.perplexity.ai)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# LM Studio (local, no API key needed)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=loaded-model

# SQL Server (Connect Module) — Docker
SQLSERVER_SERVER=localhost
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=SqlServer@123!
SQLSERVER_DATABASE=WOVO

# PostgreSQL (Engage + AI) — Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DATABASE=wovo_new
POSTGRES_DATABASE_WOVO_AI=wovo_ai

# MySQL (Educate/Moodle) — Docker
MYSQL_HOST=127.0.0.1
MYSQL_USER=moodle
MYSQL_PASSWORD=moodlepass
MYSQL_DATABASE=iomadprod

# ─── Logging ───
# LOG_FILE=logs/wovo.log        # Enable file logging (default: console only)
# LOG_LEVEL=info                 # debug | info | warn | error (default: info)
