# ─── Active AI Provider ───
# Switch between providers as credits deplete.
# Valid values: openai | nim | perplexity | lmstudio
AI_PROVIDER=nim

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:4b

# OpenAI API Key for LLM features
OPENAI_API_KEY=your_api_key_here

GOOGLE_GENERATIVE_AI_API_KEY=""

# NVIDIA NIM (https://build.nvidia.com — 1000 free inference credits)
NIM_API_KEY=""

# Perplexity (https://docs.perplexity.ai)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# LM Studio (local, no API key needed)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=loaded-model

# SQL Server Configuration (Connect Module)
SQLSERVER_USER=net_read_offline
SQLSERVER_PASSWORD=
SQLSERVER_DATABASE=WOVO
SQLSERVER_SERVER=rds-mssql.c82p8fd7rdnk.ap-southeast-1.rds.amazonaws.com

# PostgreSQL Configuration (Engage Module)
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_DATABASE=wovo_new
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Drizzle ORM (separate DB for AI tables)
POSTGRES_DATABASE_WOVO_AI=wovo_ai

# MySQL Configuration (Educate Module)
MYSQL_HOST=13.213.70.189
MYSQL_USER=moodle_admin_offline
MYSQL_PASSWORD=
MYSQL_DATABASE=iomadprod

# ─── Local Docker DB Values ───────────────────────────────────────────────────
# Copy these into .env.local when running against local Docker containers.
# Start containers: docker compose up -d

# SQL Server (Connect Module) — Docker
# SQLSERVER_SERVER=localhost
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=SqlServer@123!
# SQLSERVER_DATABASE=WOVO

# PostgreSQL (Engage + AI) — Docker
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=pguser
# POSTGRES_PASSWORD=pgpass
# POSTGRES_DATABASE=wovo_new
# POSTGRES_DATABASE_WOVO_AI=wovo_ai

# MySQL (Educate/Moodle) — Docker
# MYSQL_HOST=127.0.0.1
# MYSQL_USER=moodle
# MYSQL_PASSWORD=moodlepass
# MYSQL_DATABASE=iomadprod
